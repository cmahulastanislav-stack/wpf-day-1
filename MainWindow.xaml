<Window x:Class="MyWpfApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="My WPF App"
        Width="800"
        Height="500"
        MinWidth="400"
        MinHeight="300">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Background="LightGray" Grid.Row="0">
            <Button Content="Головна" Width="100" Margin="5"/>
            <Button Content="Сторінка 1" Width="100" Margin="5"/>
            <Button Content="Сторінка 2" Width="100" Margin="5"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="10">

            <TextBlock Text="Введіть дані:" FontSize="18" Margin="0,0,0,10"/>

            <TextBox Name="InputBox" Width="200" Margin="0,0,0,10"/>

            <Button Content="Натисни мене" Width="150" Click="Button_Click"/>

            <TextBlock Name="ResultText" FontSize="16" Margin="0,10,0,0"/>

        </StackPanel>

        <StatusBar Grid.Row="2">
            <StatusBarItem Content="Готово"/>
        </StatusBar>

    </Grid>
</Window>