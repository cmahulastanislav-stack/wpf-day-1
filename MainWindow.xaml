<Window x:Class="MyWpfApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="My WPF App"
        Width="800"
        Height="500"
        MinWidth="400"
        MinHeight="300">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal"
                    Background="LightGray"
                    Grid.Row="0"
                    Margin="5">

            <Button Content="Головна" Width="100" Margin="5" Click="Home_Click"/>
            <Button Content="Сторінка 1" Width="100" Margin="5" Click="List_Click"/>
            <Button Content="Сторінка 2" Width="100" Margin="5" Click="Settings_Click"/>

        </StackPanel>

        <Frame x:Name="MainFrame" Grid.Row="1" Margin="10"/>

        <StatusBar Grid.Row="2">
            <StatusBarItem Content="Готово"/>
        </StatusBar>

    </Grid>
</Window>